# Databricks workspace(s) for Genie Conversational API
# Option 1: Multi-workspace (JSON array)
# DATABRICKS_WORKSPACES=[{"url":"https://workspace1.cloud.databricks.com","token":"dapi..."},{"url":"https://workspace2.cloud.databricks.com","token":"dapi..."}]
# Option 2: Single workspace (legacy, still supported)
DATABRICKS_WORKSPACE_URL=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_personal_access_token

# Atlan instance (OAuth tokens come from frontend via @atlanhq/atlan-auth SDK)
ATLAN_INSTANCE_URL=https://databricks.atlan.com

# Port (Render sets this automatically; local dev only)
PORT=10000
